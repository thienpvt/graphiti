# syntax=docker/dockerfile:1
# Standalone Graphiti MCP Server Image
# This image runs only the MCP server and connects to an external database (Neo4j or FalkorDB)

FROM ghcr.io/astral-sh/uv:0.8.15 AS uv
FROM python:3.11-slim-bookworm

# Install uv without fetching an installer during the build.
COPY --from=uv /uv /uvx /bin/

# Configure uv for optimal Docker usage
ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PYTHON_DOWNLOADS=never \
    MCP_SERVER_HOST="0.0.0.0" \
    PYTHONUNBUFFERED=1

# Copy graphiti-core from the repository-root build context.
WORKDIR /app
COPY pyproject.toml README.md LICENSE ./
COPY graphiti_core/ ./graphiti_core/

# Set up MCP server directory.
WORKDIR /app/mcp

# Keep locked third-party versions, but replace graphiti-core's registry source with /app.
COPY mcp_server/pyproject.toml mcp_server/uv.lock ./
RUN printf '\n[tool.uv.sources]\ngraphiti-core = { path = "..", editable = false }\n' >> pyproject.toml && \
    uv lock

# Install runtime dependencies only. Optional LLM providers can use a custom image;
# the default OpenAI client and both graph drivers are included here.
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --no-group dev

# Store version from the copied local project.
RUN python -c "import tomllib; print(tomllib.load(open('/app/pyproject.toml', 'rb'))['project']['version'])" \
    > /app/mcp/.graphiti-core-version

# Copy MCP server application code.
COPY mcp_server/main.py ./
COPY mcp_server/src/ ./src/
COPY mcp_server/config/ ./config/

# Create log directory
RUN mkdir -p /var/log/graphiti

# Add Docker labels with version information
ARG MCP_SERVER_VERSION=1.0.2
ARG BUILD_DATE
ARG VCS_REF
LABEL org.opencontainers.image.title="Graphiti MCP Server (Standalone)" \
      org.opencontainers.image.description="Standalone Graphiti MCP server for external Neo4j or FalkorDB" \
      org.opencontainers.image.version="${MCP_SERVER_VERSION}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.revision="${VCS_REF}" \
      org.opencontainers.image.vendor="Zep AI" \
      org.opencontainers.image.source="https://github.com/zep-ai/graphiti"

# Expose MCP server port
EXPOSE 8000

# Health check - verify MCP server is responding
HEALTHCHECK --interval=10s --timeout=5s --start-period=15s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health', timeout=4)"

# Run the MCP server
CMD ["uv", "run", "--no-sync", "main.py"]
